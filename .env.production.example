# ===== Application =====
APP_NAME="Bank Sampah Emakid"
APP_ENV=production
APP_DEBUG=false
APP_KEY=
APP_URL=https://banksampahemakid.my.id

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID
APP_TIMEZONE=Asia/Jakarta

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=info

# ===== Database (infra-mysql shared instance) =====
DB_CONNECTION=mysql
DB_HOST=infra-mysql
DB_PORT=3306
DB_DATABASE=bank_sampah_emakid
DB_USERNAME=bse_user
DB_PASSWORD=BseEmakid_2026_Secure!

# ===== Session / Cache / Queue =====
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

CACHE_STORE=database

QUEUE_CONNECTION=database

# ===== Mail (log in production unless SMTP set) =====
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@banksampahemakid.my.id"
MAIL_FROM_NAME="${APP_NAME}"

# ===== Cloudflare Tunnel =====
# Set GHCR_OWNER and IMAGE_TAG, or override at deploy.
GHCR_OWNER=fredli4qooni
IMAGE_TAG=latest
CLOUDFLARE_TUNNEL_TOKEN=PASTE_TUNNEL_TOKEN_HERE